generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  createdAt  DateTime   @default(now())
  fullName   String
  image      String?
  password   String
  role       Role       @default(TOURISTE)
  bio        String?
  activities Activity[]
  Housing    Housing[]
}

model Activity {
  id          Int              @id @default(autoincrement())
  title       String
  description String
  price       Float
  date        DateTime
  location    String
  latitude    Float
  longitude   Float
  images      String[]
  status      ActivityStatus   @default(APPROVED)
  capacity    Int
  category    ActivityCategory
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  creatorId   Int
  creator     User             @relation(fields: [creatorId], references: [id])

  @@index([location])
  @@index([date])
  @@index([category])
  @@index([status])
  @@index([creatorId])
}

model Housing {
  id            String      @id
  title         String
  description   String
  location      String
  type          HousingType
  floors        Int
  rooms         Int
  familyMembers Int
  maxTourists   Int
  maxStayDays   Int
  images        String[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  ownerId       Int
  User          User        @relation(fields: [ownerId], references: [id])
}

enum Role {
  CITOYEN
  TOURISTE
}

enum ActivityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityCategory {
  ART_HERITAGE
  GASTRONOMY
  COASTAL_ESCAPE
  HISTORICAL_TOUR
  ARTISAN_WORKSHOP
  DESERT_EXPEDITION
  NATURE_ADVENTURE
  CULTURAL_EVENT
  WELLNESS
  OTHER
}

enum HousingType {
  APARTMENT
  VILLA
  STUDIO
  TRADITIONAL_HOUSE
  FARM_STAY
  GUESTHOUSE
  RIAD
  CHALET
}
